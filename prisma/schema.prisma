generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BUYER
  DEALER
  ADMIN
  DEVELOPER
  MANAGER
  SALES_AGENT
  MODERATOR
}

enum ListingStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  SOLD
  HIDDEN
  RESERVED
  ARCHIVED
  PENDING_DELETION
  DELETED
  EXPIRED
  REJECTED
}

enum SellerAccountStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SUSPENDED
}

enum SellerSharingStatus {
  ENABLED
  DISABLED
  SUSPENDED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  NONE
}

enum PaymentMethodType {
  STANDARD_BANK
  NATIONAL_BANK
  MPAMBA
  AIRTEL_MONEY
}

enum SubscriptionPaymentStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DeletionRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  REGISTRATION_APPROVED
  REGISTRATION_REJECTED
  LISTING_SUBMITTED
  LISTING_APPROVED
  LISTING_REJECTED
  LISTING_CHANGES_REQUESTED
  LISTING_HIDDEN
  LISTING_REMOVED
  DELETION_REQUESTED
  DELETION_APPROVED
  DELETION_REJECTED
  PAYMENT_SUBMITTED
  PAYMENT_CONFIRMED
  PAYMENT_REJECTED
  TRIAL_ENDING_7
  TRIAL_ENDING_3
  SUBSCRIPTION_EXPIRED
  ADMIN_NEW_SELLER
  ADMIN_NEW_LISTING
  ADMIN_DELETION_REQUEST
  ADMIN_PAYMENT_PROOF
  SELLER_SHARING_ENABLED
  SELLER_SHARING_DISABLED
  SELLER_SHARING_SUSPENDED
}

enum SellerType {
  PRIVATE
  DEALER
}

enum Transmission {
  MANUAL
  AUTOMATIC
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
  ELECTRIC
}

enum Drivetrain {
  TWO_WD
  FOUR_WD
  AWD
}

enum BodyType {
  SEDAN
  HATCHBACK
  SUV
  PICKUP
  VAN
  MINIBUS
  WAGON
  COUPE
  TRUCK
  MOTORCYCLE
}

enum SaleCondition {
  NEW
  FOREIGN_USED
  LOCALLY_USED
  FOR_PARTS
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
  ACTIONED
}

enum PhotoCategory {
  OUTER_VIEW
  SEATS
  DASHBOARD
  SUNROOF
  INSTRUMENT_CLUSTER
  STEERING_WHEEL
  BOOTSPACE
  GEAR
  HEAD_LIGHT_TAIL_LIGHTS
  DOORS_AND_CONTROLS
  AC
  AIRBAGS
  CHARGING_PORTS
  STORAGE
  EXTERIOR_CLOSEUPS
  OTHER
}

model District {
  id       String    @id @default(cuid())
  name     String    @unique
  listings Listing[]
}

model User {
  id              String    @id @default(cuid())
  phone           String    @unique
  name            String?
  email           String?   @unique
  role            UserRole  @default(BUYER)
  active          Boolean   @default(true)
  phoneVerifiedAt DateTime?
  idVerifiedAt    DateTime?
  createdAt       DateTime  @default(now())

  sellerAccount              SellerAccount?
  listings                   Listing[]
  favorites                  Favorite[]
  savedSearches              SavedSearch[]
  sentMessages               Message[]                @relation("MessageSender")
  buyerConvos                Conversation[]           @relation("ConversationBuyer")
  sellerConvos               Conversation[]           @relation("ConversationSeller")
  reviewsGiven               Review[]                 @relation("ReviewAuthor")
  reviewsReceived            Review[]                 @relation("ReviewSubject")
  reports                    Report[]
  modelPhotoUploads          ModelPhoto[]
  notifications              Notification[]
  deletionRequests           ListingDeletionRequest[] @relation("DeletionRequestedBy")
  resolvedDeletions          ListingDeletionRequest[] @relation("DeletionResolvedBy")
  confirmedPayments          SubscriptionPayment[]    @relation("PaymentConfirmedBy")
  settingsUpdates            SiteSettingsHistory[]    @relation("SettingsChangedBy")
  pageViews                  PageView[]
  searchLogs                 SearchLog[]
  backupsCreated             Backup[]                 @relation("BackupCreatedBy")
  otpDeliveryLogs            OtpDeliveryLog[]         @relation("OtpLogUser")
  otpVerifications           OtpVerificationLog[]     @relation("OtpVerificationUser")
  otpAuditActions            OtpAuditLog[]            @relation("OtpAuditActor")
  otpSettingsEdits           OtpSettings[]            @relation("OtpSettingsUpdatedBy")
  trustedDevices             TrustedDevice[]
  authPolicyEdits            AuthPolicySettings[]     @relation("AuthPolicyUpdatedBy")
  sellerSharingSettingsEdits SellerSharingSettings[]  @relation("SellerSharingSettingsUpdatedBy")
}

enum OtpPurpose {
  LOGIN
  REGISTRATION
  PASSWORD_RESET
  CHANGE_PHONE
  CHANGE_EMAIL
  HIGH_RISK_LOGIN
  TWO_FACTOR
}

enum OtpChannel {
  SMS
  WHATSAPP
  EMAIL
}

enum OtpFormat {
  NUMERIC
  ALPHANUMERIC
}

enum OtpEnvironment {
  SANDBOX
  PRODUCTION
}

enum OtpProviderRole {
  PRIMARY
  BACKUP
}

enum OtpDeliveryStatus {
  SENT
  FAILED
}

model OtpCode {
  id        String     @id @default(cuid())
  phone     String?
  email     String?
  code      String
  purpose   OtpPurpose @default(LOGIN)
  channel   OtpChannel @default(SMS)
  expiresAt DateTime
  consumed  Boolean    @default(false)
  createdAt DateTime   @default(now())

  deliveryLogs     OtpDeliveryLog[]
  verificationLogs OtpVerificationLog[]

  @@index([phone])
  @@index([email])
}

model SellerAccount {
  id                 String  @id @default(cuid())
  userId             String  @unique
  user               User    @relation(fields: [userId], references: [id])
  businessName       String
  registrationNumber String?
  verified           Boolean @default(false)
  logoUrl            String?
  description        String?
  district           String?
  whatsappNumber     String?
  callPhoneNumber    String?

  status          SellerAccountStatus @default(PENDING_APPROVAL)
  rejectionReason String?
  suspendedAt     DateTime?

  trialEndsAt           DateTime?
  trial7DayNoticeSentAt DateTime?
  trial3DayNoticeSentAt DateTime?
  subscriptionStatus    SubscriptionStatus @default(NONE)
  subscriptionExpiresAt DateTime?

  slug                    String?             @unique
  sharingStatus           SellerSharingStatus @default(ENABLED)
  shareLinkPageViews      Int                 @default(0)
  shareLinkListingClicks  Int                 @default(0)
  shareLinkPhoneClicks    Int                 @default(0)
  shareLinkWhatsappClicks Int                 @default(0)
  shareLinkShareClicks    Int                 @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments SubscriptionPayment[]

  @@index([status])
  @@index([sharingStatus])
}

model SubscriptionPlan {
  id           String   @id @default(cuid())
  name         String
  priceMwk     Int
  durationDays Int
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  payments SubscriptionPayment[]
}

model PaymentMethod {
  id            String            @id @default(cuid())
  type          PaymentMethodType
  label         String
  accountName   String?
  accountNumber String?
  phoneNumber   String?
  instructions  String?
  enabled       Boolean           @default(true)
  sortOrder     Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  payments SubscriptionPayment[]
}

model SubscriptionPayment {
  id              String                    @id @default(cuid())
  sellerAccountId String
  sellerAccount   SellerAccount             @relation(fields: [sellerAccountId], references: [id], onDelete: Cascade)
  planId          String?
  plan            SubscriptionPlan?         @relation(fields: [planId], references: [id])
  paymentMethodId String?
  paymentMethod   PaymentMethod?            @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  amountMwk       Int
  proofUrl        String
  status          SubscriptionPaymentStatus @default(PENDING)
  notes           String?
  submittedAt     DateTime                  @default(now())
  confirmedAt     DateTime?
  confirmedById   String?
  confirmedBy     User?                     @relation("PaymentConfirmedBy", fields: [confirmedById], references: [id])

  @@index([status])
}

model ListingDeletionRequest {
  id             String                @id @default(cuid())
  listingId      String
  listing        Listing               @relation(fields: [listingId], references: [id])
  sellerId       String
  seller         User                  @relation("DeletionRequestedBy", fields: [sellerId], references: [id])
  reason         String?
  previousStatus ListingStatus
  status         DeletionRequestStatus @default(PENDING)
  requestedAt    DateTime              @default(now())
  resolvedAt     DateTime?
  resolvedById   String?
  resolvedBy     User?                 @relation("DeletionResolvedBy", fields: [resolvedById], references: [id])

  @@index([status])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String
  createdAt DateTime         @default(now())
  readAt    DateTime?

  @@index([userId, readAt])
}

model Brand {
  id            String     @id @default(cuid())
  name          String     @unique
  slug          String     @unique
  originCountry String?
  logoUrl       String?
  history       String?
  createdAt     DateTime   @default(now())
  models        CarModel[]
}

model CarModel {
  id                     String     @id @default(cuid())
  brandId                String
  brand                  Brand      @relation(fields: [brandId], references: [id])
  name                   String
  slug                   String
  yearStart              Int
  yearEnd                Int?
  bodyType               BodyType
  fuelType               FuelType
  drivetrain             Drivetrain
  engineCc               Int?
  seating                Int?
  description            String?
  strengths              String?
  faults                 String?
  partAvailabilityRating Int? // 1-5, community-rated
  isClassic              Boolean    @default(false)
  baseValueMwk           Int? // fallback estimated value when there's no listing history yet
  createdAt              DateTime   @default(now())

  photos   ModelPhoto[]
  listings Listing[]

  @@unique([brandId, slug])
  @@index([isClassic])
}

model ModelPhoto {
  id            String   @id @default(cuid())
  carModelId    String
  carModel      CarModel @relation(fields: [carModelId], references: [id])
  url           String
  caption       String?
  submittedById String?
  submittedBy   User?    @relation(fields: [submittedById], references: [id])
  approved      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model Listing {
  id         String     @id @default(cuid())
  sellerId   String
  seller     User       @relation(fields: [sellerId], references: [id])
  sellerType SellerType @default(PRIVATE)
  carModelId String?
  carModel   CarModel?  @relation(fields: [carModelId], references: [id])

  title         String
  brandName     String
  modelName     String
  year          Int
  priceMwk      Int
  mileageKm     Int
  transmission  Transmission
  fuelType      String?
  bodyType      String?
  engineCc      Int?
  seating       Int?
  drivetrain    Drivetrain?
  saleCondition SaleCondition @default(FOREIGN_USED)
  condition     String
  description   String?
  videoUrl      String?

  districtId String?
  district   District? @relation(fields: [districtId], references: [id])

  status        ListingStatus @default(DRAFT)
  reviewNotes   String?
  featured      Boolean       @default(false)
  featuredUntil DateTime?
  boosted       Boolean       @default(false)
  viewCount     Int           @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expiresAt DateTime?

  photos           ListingPhoto[]
  favorites        Favorite[]
  conversations    Conversation[]
  reports          Report[]
  reviews          Review[]
  deletionRequests ListingDeletionRequest[]

  @@unique([sellerId, title])
  @@index([status])
  @@index([brandName, modelName])
  @@index([districtId])
  @@index([saleCondition])
}

model ListingPhoto {
  id        String        @id @default(cuid())
  listingId String
  listing   Listing       @relation(fields: [listingId], references: [id])
  url       String
  category  PhotoCategory @default(OTHER)
  position  Int           @default(0)
  createdAt DateTime      @default(now())

  @@index([listingId, category])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
}

model SavedSearch {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  label       String
  criteria    Json
  notifyBySms Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Conversation {
  id        String    @id @default(cuid())
  listingId String
  listing   Listing   @relation(fields: [listingId], references: [id])
  buyerId   String
  buyer     User      @relation("ConversationBuyer", fields: [buyerId], references: [id])
  sellerId  String
  seller    User      @relation("ConversationSeller", fields: [sellerId], references: [id])
  createdAt DateTime  @default(now())
  messages  Message[]

  @@unique([listingId, buyerId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])
  body           String
  createdAt      DateTime     @default(now())
}

model Review {
  id                 String       @id @default(cuid())
  authorId           String
  author             User         @relation("ReviewAuthor", fields: [authorId], references: [id])
  subjectId          String?
  subject            User?        @relation("ReviewSubject", fields: [subjectId], references: [id])
  listingId          String?
  listing            Listing?     @relation(fields: [listingId], references: [id])
  rating             Int
  title              String?
  comment            String
  displayAnonymously Boolean      @default(false)
  status             ReviewStatus @default(PENDING)
  createdAt          DateTime     @default(now())

  @@index([status])
  @@index([subjectId])
}

model Report {
  id         String       @id @default(cuid())
  listingId  String
  listing    Listing      @relation(fields: [listingId], references: [id])
  reporterId String
  reporter   User         @relation(fields: [reporterId], references: [id])
  reason     String
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())
}

model LoginAttempt {
  id        String   @id @default(cuid())
  phone     String
  success   Boolean
  reason    String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([createdAt])
}

/// Singleton row (id is always "singleton") holding site-wide branding, contact,
/// and configuration data managed through the Developer Panel.
model SiteSettings {
  id String @id @default("singleton")

  siteName       String  @default("Halesah Galimoto Hub")
  tagline        String?
  logoUrl        String?
  faviconUrl     String?
  primaryColor   String  @default("#137d54")
  secondaryColor String  @default("#0D2A4A")
  fontFamily     String  @default("Inter")

  contactEmail       String?
  contactPhone       String?
  whatsappNumber     String?
  address            String?
  companyName        String?
  registrationNumber String?

  currency       String @default("MWK")
  timezone       String @default("Africa/Blantyre")
  taxRatePercent Float?

  maintenanceMode    Boolean @default(false)
  maintenanceMessage String?

  facebookUrl  String?
  twitterUrl   String?
  instagramUrl String?
  tiktokUrl    String?

  smtpHost      String?
  smtpPort      Int?
  smtpUsername  String?
  smtpPassword  String?
  smtpFromEmail String?

  notifyEmailEnabled    Boolean @default(true)
  notifyWhatsappEnabled Boolean @default(true)

  updatedAt DateTime @updatedAt
}

model SiteSettingsHistory {
  id          String   @id @default(cuid())
  snapshot    Json
  changedById String?
  changedBy   User?    @relation("SettingsChangedBy", fields: [changedById], references: [id])
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model HomepageSection {
  id        String   @id @default(cuid())
  key       String   @unique
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  title     String?
  subtitle  String?
  ctaLabel  String?
  ctaHref   String?
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  ipAddress String?
  userAgent String?
  referrer  String?
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
}

model SearchLog {
  id           String   @id @default(cuid())
  query        String
  resultsCount Int?
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

enum BackupType {
  DATABASE
  MEDIA
  CONFIG
}

enum BackupStatus {
  PENDING
  COMPLETED
  FAILED
}

model Backup {
  id           String       @id @default(cuid())
  type         BackupType
  status       BackupStatus @default(PENDING)
  filename     String
  sizeBytes    Int?
  errorMessage String?
  createdById  String?
  createdBy    User?        @relation("BackupCreatedBy", fields: [createdById], references: [id])
  createdAt    DateTime     @default(now())

  @@index([createdAt])
}

/// One row per configured OTP delivery provider instance (e.g. one Twilio SMS
/// account, one Meta WhatsApp Cloud API app, one SendGrid email account).
/// `credentialsEncrypted` holds the full provider-specific field set as a
/// single AES-256-GCM encrypted JSON blob — see src/lib/otpEncryption.ts.
/// Exactly one PRIMARY row per channel is treated as "active"; BACKUP rows
/// are tried in ascending `priority` order if the primary send fails.
model OtpProviderConfig {
  id                   String          @id @default(cuid())
  providerKey          String
  channel              OtpChannel
  label                String
  environment          OtpEnvironment  @default(PRODUCTION)
  chainRole            OtpProviderRole @default(PRIMARY)
  priority             Int             @default(0)
  isActive             Boolean         @default(false)
  credentialsEncrypted String
  dailyLimit           Int?
  monthlyLimit         Int?
  lastTestedAt         DateTime?
  lastTestStatus       String?
  lastTestResponse     String?
  lastTestError        String?
  lastTestResponseMs   Int?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  deliveryLogs OtpDeliveryLog[]

  @@index([channel])
  @@index([channel, chainRole, priority])
}

/// Singleton row (id is always "singleton") holding all OTP behavior
/// settings configured from the Developer Panel.
model OtpSettings {
  id                     String    @id @default("singleton")
  otpEnabled             Boolean   @default(true)
  otpLength              Int       @default(6)
  otpFormat              OtpFormat @default(NUMERIC)
  otpExpiryMinutes       Int       @default(10)
  maxVerifyAttempts      Int       @default(5)
  maxResendAttempts      Int       @default(3)
  resendCooldownSeconds  Int       @default(60)
  maxRequestsPerHour     Int       @default(5)
  maxRequestsPerDay      Int       @default(20)
  lockoutDurationMinutes Int       @default(30)
  allowedCountries       String?
  blockedCountries       String?
  defaultCountryCode     String    @default("+265")
  channelPriority        Json      @default("[\"SMS\", \"WHATSAPP\", \"EMAIL\"]")
  webhookDeliveryUrl     String?
  webhookVerificationUrl String?
  webhookFailureUrl      String?
  updatedAt              DateTime  @updatedAt
  updatedById            String?
  updatedBy              User?     @relation("OtpSettingsUpdatedBy", fields: [updatedById], references: [id])
}

/// Customizable message templates per purpose + channel. {{OTP}}, {{APP_NAME}},
/// {{USER_NAME}}, {{EXPIRY}}, {{DATE}}, {{TIME}} placeholders are substituted
/// at send time — see src/lib/otpTemplates.ts.
model OtpTemplate {
  id        String     @id @default(cuid())
  purpose   OtpPurpose
  channel   OtpChannel
  subject   String?
  body      String
  updatedAt DateTime   @updatedAt

  @@unique([purpose, channel])
}

/// One row per delivery attempt — the "OTP Requests" + delivery log table.
model OtpDeliveryLog {
  id               String             @id @default(cuid())
  otpCodeId        String?
  otpCode          OtpCode?           @relation(fields: [otpCodeId], references: [id])
  userId           String?
  user             User?              @relation("OtpLogUser", fields: [userId], references: [id])
  purpose          OtpPurpose
  channel          OtpChannel
  destination      String
  providerConfigId String?
  providerConfig   OtpProviderConfig? @relation(fields: [providerConfigId], references: [id])
  providerKey      String
  status           OtpDeliveryStatus
  providerResponse String?
  errorMessage     String?
  responseTimeMs   Int?
  ipAddress        String?
  userAgent        String?
  country          String?
  createdAt        DateTime           @default(now())

  @@index([createdAt])
  @@index([status])
  @@index([purpose])
  @@index([providerKey])
}

/// One row per verification attempt — the "OTP Verifications" table.
model OtpVerificationLog {
  id          String     @id @default(cuid())
  otpCodeId   String?
  otpCode     OtpCode?   @relation(fields: [otpCodeId], references: [id])
  userId      String?
  user        User?      @relation("OtpVerificationUser", fields: [userId], references: [id])
  destination String
  purpose     OtpPurpose
  success     Boolean
  reason      String?
  ipAddress   String?
  userAgent   String?
  country     String?
  createdAt   DateTime   @default(now())

  @@index([createdAt])
  @@index([success])
}

/// Active rate-limit lockouts — the "Rate Limits" table. A row here blocks
/// further OTP requests/verifications for `identifier` until `blockedUntil`.
model OtpLockout {
  id           String   @id @default(cuid())
  identifier   String
  scope        String
  reason       String
  blockedUntil DateTime
  createdAt    DateTime @default(now())

  @@index([identifier])
  @@index([blockedUntil])
}

/// Records every change to OTP provider configuration/credentials/settings —
/// never stores secret values, only human-readable summaries of what changed.
model OtpAuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation("OtpAuditActor", fields: [actorId], references: [id])
  action     String
  targetType String?
  targetId   String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

/// Outbound webhook fire log — delivery/verification/failure notifications
/// sent to the URLs configured on OtpSettings.
model OtpWebhookLog {
  id           String   @id @default(cuid())
  kind         String
  url          String
  statusCode   Int?
  success      Boolean
  payload      String?
  responseBody String?
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([kind])
}

/// A browser/device that has been remembered after a successful OTP login,
/// letting subsequent logins from it skip OTP per the enforcement policy.
/// `tokenHash` is a SHA-256 hash of the opaque token stored in the visitor's
/// cookie — the raw token is never persisted.
model TrustedDevice {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String    @unique
  label        String
  browser      String?
  os           String?
  ipAddress    String?
  lastActiveAt DateTime  @default(now())
  createdAt    DateTime  @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?

  @@index([userId])
}

/// Singleton row (id is always "singleton") holding the OTP enforcement
/// policy and trusted-device settings, configured entirely from the
/// Developer Panel — see src/lib/authPolicy.ts.
model AuthPolicySettings {
  id String @id @default("singleton")

  // Enforcement policy
  requireOtpOnRegistration Boolean @default(true)
  requireOtpOnNewDevice    Boolean @default(true)
  requireOtpOnChangePhone  Boolean @default(true)
  requireOtpOnChangeEmail  Boolean @default(true)
  forceOtpForAdmins        Boolean @default(true)
  forceOtpForRoles         Json    @default("[]")

  // Trusted devices
  trustedDevicesEnabled        Boolean @default(true)
  trustedDeviceValidityDays    Int     @default(30)
  maxTrustedDevicesPerUser     Int     @default(5)
  forceOtpAfterDeviceExpiry    Boolean @default(true)
  forceOtpAfterLogout          Boolean @default(false)
  forceOtpAfterEmailChange     Boolean @default(true)
  forceOtpAfterPhoneChange     Boolean @default(true)
  forceOtpAfterSuspiciousLogin Boolean @default(true)

  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation("AuthPolicyUpdatedBy", fields: [updatedById], references: [id])
}

/// Singleton row (id is always "singleton") holding the Seller Listing Share
/// Link feature configuration, managed from Developer Panel → Marketplace
/// Features → Seller Inventory Sharing. Per-seller enable/disable/suspend is
/// tracked on SellerAccount.sharingStatus instead (see Manager Panel).
model SellerSharingSettings {
  id String @id @default("singleton")

  enabled Boolean @default(true)

  allowCopyLink      Boolean @default(true)
  allowWhatsappShare Boolean @default(true)
  allowFacebookShare Boolean @default(true)
  allowTwitterShare  Boolean @default(true)
  allowTelegramShare Boolean @default(true)
  allowEmailShare    Boolean @default(true)
  allowNativeShare   Boolean @default(true)

  urlPrefix       String @default("seller")
  slugFormat      String @default("BUSINESS_NAME")
  fallbackUrl     String @default("/")
  disabledMessage String @default("Inventory sharing is currently disabled.")

  seoIndexing       Boolean @default(true)
  seoSitemap        Boolean @default(true)
  seoStructuredData Boolean @default(true)
  seoOpenGraph      Boolean @default(true)
  seoTwitterCard    Boolean @default(true)

  analyticsPageViews      Boolean @default(true)
  analyticsListingClicks  Boolean @default(true)
  analyticsPhoneClicks    Boolean @default(true)
  analyticsWhatsappClicks Boolean @default(true)
  analyticsShareCounts    Boolean @default(true)

  securityRequireVerification Boolean @default(false)
  securityHideLocation        Boolean @default(false)
  securityHidePhone           Boolean @default(false)
  securityHideWhatsapp        Boolean @default(false)
  securityRateLimitEnabled    Boolean @default(false)
  securityRateLimitPerMinute  Int     @default(30)

  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation("SellerSharingSettingsUpdatedBy", fields: [updatedById], references: [id])
}
