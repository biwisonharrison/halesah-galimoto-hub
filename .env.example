# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://galimoto:galimoto@localhost:5432/galimoto_hub?schema=public"

# Secret used to sign session JWTs — generate with `openssl rand -hex 32`
SESSION_SECRET="dev-only-secret-change-me"

# OTP provider: "console" logs codes to the server console (default, no account needed).
# Set to "africastalking" to send real SMS via Africa's Talking instead.
OTP_PROVIDER="console"

# Only needed when OTP_PROVIDER="africastalking".
# Get these from africastalking.com under Settings > API Key.
# Use username="sandbox" while testing with a trial account.
AFRICASTALKING_API_KEY=""
AFRICASTALKING_USERNAME=""
AFRICASTALKING_SENDER_ID=""

# Only needed in production (e.g. on Vercel). Leave unset for local dev —
# uploads fall back to public/uploads/ on disk. Set automatically when you
# add Vercel Blob storage to your project in the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=""
