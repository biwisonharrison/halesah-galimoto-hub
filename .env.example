# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://galimoto:galimoto@localhost:5432/galimoto_hub?schema=public"

# Secret used to sign session JWTs — generate with `openssl rand -hex 32`
SESSION_SECRET="dev-only-secret-change-me"

# Legacy fallback OTP provider, used only until an OTP provider is configured
# from the Developer Panel (Developer > OTP Configuration). Once a provider is
# active there, all OTP delivery is controlled from the database, not env vars.
OTP_PROVIDER="console"

# Encrypts OTP provider credentials (API keys, tokens, passwords) at rest in the
# database — generate with `openssl rand -hex 32`. Required for the OTP
# Configuration panel to save any provider. Changing this key makes all
# previously-saved provider credentials unreadable, so back it up somewhere safe.
OTP_ENCRYPTION_KEY=""
